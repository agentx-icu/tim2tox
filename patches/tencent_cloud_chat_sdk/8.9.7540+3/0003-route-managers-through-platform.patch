+// Tim2Tox fix: When isCustomPlatform is true (Tim2ToxSdkPlatform registered),
+// conversation operations route through TencentCloudChatSdkPlatform.instance
+// instead of the native C API (TIMConversationManager). The native C API has
+// no knowledge of Tox conversations, so it returned empty/default
+// V2TimConversation objects, causing the chat header to flash between correct
+// and empty avatar/nickname.
+
 class V2TIMConversationManager {
   Future<void> setConversationListener({
     required V2TimConversationListener listener,
   }) {
-    if (kIsWeb) {
+    if (TencentCloudChatSdkPlatform.instance.isPlatformRouted) {
       return TencentCloudChatSdkPlatform.instance
-        .setConversationListener(listener: listener);
+          .setConversationListener(listener: listener);
     }
 
     TIMConversationManager.instance
         .setConversationListener(listener: listener);
-  
     return Future.value();
   }
 
   Future<void> addConversationListener({
     required V2TimConversationListener listener,
   }) {
-    if (kIsWeb) {
+    if (TencentCloudChatSdkPlatform.instance.isPlatformRouted) {
       return TencentCloudChatSdkPlatform.instance
-        .addConversationListener(listener: listener);
+          .addConversationListener(listener: listener);
     }
 
     TIMConversationManager.instance
         .addConversationListener(listener: listener);
-
     return Future.value();
   }
 
   Future<void> removeConversationListener(
       {V2TimConversationListener? listener}) {
-    if (kIsWeb) {
+    if (TencentCloudChatSdkPlatform.instance.isPlatformRouted) {
       return TencentCloudChatSdkPlatform.instance.removeConversationListener(
         listener: listener,
       );
     }
-      
+
     TIMConversationManager.instance.removeConversationListener(
       listener: listener,
     );
-
     return Future.value();
   }
 
