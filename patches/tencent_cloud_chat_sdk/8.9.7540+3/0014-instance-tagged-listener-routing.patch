+  /// Tim2tox multi-instance routing ŌĆö dispatch lookup.
+  ///
+  /// If `NativeLibraryManager.currentDispatchInstanceId` is non-null /
+  /// non-zero AND has at least one registered per-instance listener, return
+  /// that bucket; otherwise fall back to the flat singleton list. The
+  /// fallback preserves byte-identical behavior for single-instance toxee.
+  List<V2TimAdvancedMsgListener> _listenersForCurrentDispatch() =>
+      listenersForInstance(NativeLibraryManager.currentDispatchInstanceId);
+
+  /// Tim2tox multi-instance routing ŌĆö public dispatch lookup.
+  ///
+  /// Returns the per-instance bucket for [instanceId] when non-null /
+  /// non-zero AND non-empty; otherwise returns the flat singleton list. Used
+  /// by `Tim2ToxSdkPlatform._notifyAdvancedMsgListeners` to filter its
+  /// singleton fan-out so an event meant for instance B does not fire
+  /// instance A's listener.
+  List<V2TimAdvancedMsgListener> listenersForInstance(int? instanceId) {
+    if (instanceId != null && instanceId != 0) {
+      final bucket = _instanceListeners[instanceId];
+      if (bucket != null && bucket.isNotEmpty) {
+        return bucket;
+      }
+    }
+    return v2TimAdvancedMsgListenerList;
+  }
