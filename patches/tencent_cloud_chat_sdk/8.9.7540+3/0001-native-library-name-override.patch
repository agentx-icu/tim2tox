From 09dabba7291ac849ce016f8bb650a2e35aafe45a Mon Sep 17 00:00:00 2001
From: tim2tox-bootstrap <bootstrap@local>
Date: Tue, 19 May 2026 02:43:24 -0700
Subject: [PATCH 1/5] 0001-native-library-name-override

---
 .../bindings/native_library_manager.dart      | 29 +++++++++++++++----
 1 file changed, 23 insertions(+), 6 deletions(-)

diff --git a/lib/native_im/bindings/native_library_manager.dart b/lib/native_im/bindings/native_library_manager.dart
index 4b0ed8d..6a99ca0 100644
--- a/lib/native_im/bindings/native_library_manager.dart
+++ b/lib/native_im/bindings/native_library_manager.dart
@@ -42,27 +42,44 @@ import 'package:tencent_cloud_chat_sdk/enum/V2TimGroupListener.dart';
 import 'package:tencent_cloud_chat_sdk/enum/V2TimSignalingListener.dart';
 import 'native_imsdk_bindings_generated.dart';
 
-const String _libName = 'dart_native_imsdk';
+/// Override the native library name before any SDK call.
+/// Default is 'dart_native_imsdk' (the original Tencent Cloud IM SDK).
+/// Call this early in main() to load a different native library.
+String _nativeLibName = 'dart_native_imsdk';
+void setNativeLibraryName(String name) {
+  _nativeLibName = name;
+}
+
 /// The dynamic library in which the symbols for [NativeImsdkBindings] can be found.
 final DynamicLibrary _dylib = () {
+  final libName = _nativeLibName;
   if (Platform.isAndroid || Platform.isLinux) {
-    return DynamicLibrary.open('lib$_libName.so');
+    return DynamicLibrary.open('lib$libName.so');
   }
 
   if (Platform.isIOS) {
-    return DynamicLibrary.open('$_libName.framework/$_libName');
+    try {
+      return DynamicLibrary.open('$libName.framework/$libName');
+    } catch (e) {
+      return DynamicLibrary.open('lib$libName.dylib');
+    }
   }
 
   if (Platform.isMacOS) {
-    return DynamicLibrary.open('$_libName.framework/Versions/A/$_libName');
+    // Try framework first, then dylib
+    try {
+      return DynamicLibrary.open('$libName.framework/Versions/A/$libName');
+    } catch (e) {
+      return DynamicLibrary.open('lib$libName.dylib');
+    }
   }
 
   if (Platform.isWindows) {
-    return DynamicLibrary.open('$_libName.dll');
+    return DynamicLibrary.open('$libName.dll');
   }
 
   if (Platform.operatingSystem == 'ohos') {
-    return DynamicLibrary.open('lib$_libName.so');
+    return DynamicLibrary.open('lib$libName.so');
   }
 
   throw UnsupportedError('Unknown platform: ${Platform.operatingSystem}');
-- 
